for each s in states,
    Theorem  Find-type-in-env_(s)  :
        forall*,
        (Lookup  : =LookupMap_(s)= map l e) ->
        (TypeOf_(s) : =TypeOf_(s)= state_env(s) map) ->
        (TypeOf : typeOf (nilEnvT) all_envs (label l) (ref t)) ->
        (_ : typeOf (nilEnvT) all_envs e t).
Proof.
    intros.
    _ : case TypeOf.
    _ : case TypeOfH.
    _ : apply H2 to H1 with env=env..
    _ : apply Uniqueness-of-lookupMap_(s) to Lookup H3.
    search
