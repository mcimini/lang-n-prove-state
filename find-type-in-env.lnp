for each s in states,
    Theorem  Find-type-in-env_(s)  :
        forall*,
        (Lookup  : =LookupMap_(s)= map l e) ->
        (TypeOfH : =TypeOf_(s)= env map) ->
        (TypeOf : typeOf (nilEnvT) env (label l) (ref t)) ->
        (_ : typeOf (nilEnvT) env e t).
Proof.
    intros.
    _ : case TypeOf.
    _ : case TypeOfH.
    _ : apply H2 to H1.
    _ : apply Uniqueness-of-lookupMap_(s) to Lookup H3.
    search