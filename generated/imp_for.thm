Define typeOfH: envH -> mapH -> prop by
typeOfH EnvH MapH := forall l, forall t, 
{lookupEnvH EnvH l t} -> 
exists e, {lookupMapH MapH l e} /\ {typeOf (nilEnvT) EnvH e t}.





Theorem Uniqueness-of-lookupMap-H : forall map L e1 e2, {lookupMapH map L e1} -> {lookupMapH map L e2} -> e1 = e2.
skip.

Theorem  Find-type-in-envH  :
    forall EnvH map L e T,
    {lookupMapH map L e} ->
    typeOfH EnvH map ->
	{lookupEnvH EnvH L T} ->
    {typeOf (nilEnvT) EnvH e T}. 
intros Lookup typeOfH LookupEnv.
	case typeOfH(keep).
	apply H1 to LookupEnv.
	apply Uniqueness-of-lookupMap-H to Lookup H2.
	search.

Theorem Uniqueness-of-lookupEnv-H : forall env L e1 e2, {lookupEnvH env L e1} -> {lookupEnvH  env L e2} -> e1 = e2.
 skip.

Theorem excluded_middle_labels-H : forall (l1 :labelH) l2, (l1 = l2) \/ (l1 = l2 -> false).
 skip.

Theorem update_implies_lookup-H :
  forall map l map' e,
  {updateMapH map l e map'} -> {lookupMapH map' l e}.

  induction on 1. intros Main.
  StUpdate : case Main.
  search.
  apply IH to StUpdate. search.

Theorem inequality_contradiction-H : 

  forall (l : labelH),

    (l = l -> false) ->

    false.

  intros Contra. Equal : assert l = l. apply Contra to Equal.

Theorem lookup_when_inequal_labels-H:

  forall l1 l2 map map' e1 e2
,
    (l1 = l2 -> false) ->
    {updateMapH map l1 e1 map'}    ->
    {lookupMapH map l2 e2} ->
    {lookupMapH map' l2 e2}.

  induction on 2.

  intros Lanld STupdate STlookup.
  STupdate : case STupdate.
      case STlookup.
          apply inequality_contradiction-H to Lanld.
          search.

      STlookup : case STlookup.
          search.
          apply IH to Lanld STupdate STlookup. search.

Theorem TypeOf-updateH: 
    forall envH map map' e T L,
      typeOfH envH map ->
	  	{lookupEnvH envH L T} ->
    {typeOf nilEnvT envH e T} ->
      {updateMapH map L e map'} ->
      typeOfH envH map'.

	  intros TypeOfH LookupEnv TypeOfE Update. 
	  TypeOfHExpanded: case TypeOfH.
	  unfold.
	  intros LookupEnvHOfGoal.
	  Landl : apply excluded_middle_labels-H with l1 = L, l2 = l.
	  Landl : case Landl.
	  % l = L
	  apply Uniqueness-of-lookupEnv-H to LookupEnvHOfGoal LookupEnv.
	  apply update_implies_lookup-H to Update.
	  search.
	  % l != L
	  LookupMap : apply TypeOfHExpanded to LookupEnvHOfGoal.
	  apply lookup_when_inequal_labels-H to Landl Update LookupMap.
	  search.

Theorem TypeOf-weakening-H: 
    forall envH map E T l,
      typeOfH envH map ->
      {typeOf nilEnvT envH E T} ->
      typeOfH (consEnvH l T envH)   (consMapH l E map).

  intros TypeOfH TypeOfE. 
  apply Type-state-envs-weakening-H to TypeOfE _ with EnvH' = (consEnvH l T envH).
  TypeOfHExpanded : case TypeOfH.
  unfold.
  intros LookupEnv.
  LookupEnv : case LookupEnv.
  search.
  TypeOfHFormulae0 : apply TypeOfHExpanded to LookupEnv.
  apply Type-state-envs-weakening-H to TypeOfHFormulae1 _ with EnvH' = (consEnvH l T envH).
  search.

Theorem TypeOf-addH : forall map E map' L T env ,  
  {addMapH map E map' L} -> typeOfH (consEnvH L T env)  (consMapH L E map) -> typeOfH (consEnvH L T env)  map'. 

  induction on 1. intros Main Lookup.
  Subset: case Main.
  search.


