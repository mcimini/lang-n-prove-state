Theorem Naming : 
    (_ : pred 0).
Proof. 
for each i in range(arity(r.conclusion[none].sourceExp[none])) :  
	if constructed(getArgs(r.conclusion[none].sourceExp[none], i)) 
	then if (arity(getArgs(r.conclusion[none].sourceExp[none], i)) = 0)
		then _ : case Typing_(i) 
		else TypeOfVar_(getArgs(getArgs(r.conclusion[none].sourceExp[none], i), 0)) : case Typing_(i) 
		endif
	else TypeOfVar_(getArgs(r.conclusion[none].sourceExp[none], i)) : apply Typing_(i) to endif
endfor


