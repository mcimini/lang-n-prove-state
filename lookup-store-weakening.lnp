for each s in extensibleStates,
    Theorem Lookup-store-weakening-_(s): 
        forall*,
        (Main : =SubsetEnv_(s)= env env') ->
        (Lookup : =LookupEnv_(s)= env l t) ->
        (_ : =LookupEnv_(s)= env' l t).
Proof.
Subset : induction on Main.
    search.
_ : apply IH0 to Subset Lookup.
    search
