 witness EnvH.  
 split.  
 search.  
 backchain Type-state-envs-weakening.  
 search.  
 MapEnvSubset0: apply IH0 to Typing0 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
  
 apply Type-state-envs-weakening to Typing1 MapEnvSubset0 .  
 search.  
 search.  
 MapEnvSubset0: apply IH0 to Typing1 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
 apply Type-state-envs-weakening to Typing0 MapEnvSubset0 .  
  
 search.  
 search.  
 BeginsnilL: apply Step. 
 Prem0: case Step(keep).  
  
 BeginsconsL: apply Step. 
 Prem0: case Step(keep).  
  
 Beginsequal: apply Step. 
 Prem0: case Step(keep).  
 TypingInsertedV1: apply Typing0. 
 TypingInsertedV2: apply Typing1. 
 TypingInsertedV3: apply Find-type-user-defined-equality to Prem0 TypingInsertedV1 TypingInsertedV2.  
 witness EnvH.  
 split.  
 search.  
 backchain Type-state-envs-weakening.  
 search.  
 MapEnvSubset0: apply IH0 to Typing0 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
  
 apply Type-state-envs-weakening to Typing1 MapEnvSubset0 .  
 search.  
 search.  
 MapEnvSubset0: apply IH0 to Typing1 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
 apply Type-state-envs-weakening to Typing0 MapEnvSubset0 .  
  
 search.  
 search.  
 Beginsderef: apply Step. 
 Prem0: case Step(keep).  
 TypingInsertedL: apply Typing0. 
 TypingInsertedV: apply Find-type-in-envH to Prem0 TypeOfH TypingInsertedL.  
  
 witness EnvH.  
 split.  
 search.  
 backchain Type-state-envs-weakening.  
 search.  
 MapEnvSubset0: apply IH0 to Typing0 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
 search.  
 search.  
 Beginsassign: apply Step. 
 Prem0: case Step(keep).  
 TypingInsertedL: apply Typing0. 
 TypingInsertedV: apply Typing1. 
 TypeOfH': apply TypeOf-updateH to TypeOfH TypingInsertedL TypingInsertedV Prem0.  
 witness EnvH.  
 split.  
 search.  
 backchain Type-state-envs-weakening.  
 search.  
 MapEnvSubset0: apply IH0 to Typing0 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
  
 apply Type-state-envs-weakening to Typing1 MapEnvSubset0 .  
 search.  
 search.  
 MapEnvSubset0: apply IH0 to Typing1 TypeOfH  Prem0.  
 witness EnvH'.  
 split.  
 search.  
 apply Type-state-envs-weakening to Typing0 MapEnvSubset0 .  
  
 search.  
 search.  
 Beginsif: apply Step. 
 Prem0: case Step(keep).  
 case Typing0(keep).  
 TypingInsertedE1: apply Typing1. 
 TypingInsertedE2: apply Typing2. 
