Theorem Progress-num: forall EnvH, forall N1, forall ty, forall H, {typeOf (nilEnvT) EnvH (num N1) ty} -> typeOfH EnvH H -> true -> progresses (num N1) H. 
skip. 


Theorem Progress-tt: forall EnvH, forall ty, forall H, {typeOf (nilEnvT) EnvH (tt) ty} -> typeOfH EnvH H -> true -> progresses (tt) H. 
skip. 


Theorem Progress-ff: forall EnvH, forall ty, forall H, {typeOf (nilEnvT) EnvH (ff) ty} -> typeOfH EnvH H -> true -> progresses (ff) H. 
skip. 


Theorem Progress-plus: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (plus E1 E2) ty} -> typeOfH EnvH H -> progresses E1 H -> progresses E2 H -> progresses (plus E1 E2) H. 
skip. 


Theorem Progress-nilL: forall EnvH, forall ty, forall H, {typeOf (nilEnvT) EnvH (nilL) ty} -> typeOfH EnvH H -> true -> progresses (nilL) H. 
skip. 


Theorem Progress-consL: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (consL E1 E2) ty} -> typeOfH EnvH H -> true -> progresses (consL E1 E2) H. 
skip. 


Theorem Progress-equal: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (equal E1 E2) ty} -> typeOfH EnvH H -> progresses E1 H -> progresses E2 H -> progresses (equal E1 E2) H. 
skip. 


Theorem Progress-deref: forall EnvH, forall E1, forall ty, forall H, {typeOf (nilEnvT) EnvH (deref E1) ty} -> typeOfH EnvH H -> progresses E1 H -> progresses (deref E1) H. 
skip. 


Theorem Progress-assign: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (assign E1 E2) ty} -> typeOfH EnvH H -> progresses E1 H -> progresses E2 H -> progresses (assign E1 E2) H. 
skip. 


Theorem Progress-if: forall EnvH, forall E1, forall E2, forall E3, forall ty, forall H, {typeOf (nilEnvT) EnvH (if E1 E2 E3) ty} -> typeOfH EnvH H -> progresses E1 H -> progresses (if E1 E2 E3) H. 
skip. 


Theorem Progress-while: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (while E1 E2) ty} -> typeOfH EnvH H -> true -> progresses (while E1 E2) H. 
skip. 


Theorem Progress-repeat: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (repeat E1 E2) ty} -> typeOfH EnvH H -> true -> progresses (repeat E1 E2) H. 
skip. 


Theorem Progress-for: forall EnvH, forall E1, forall E2, forall E3, forall E4, forall ty, forall H, {typeOf (nilEnvT) EnvH (for E1 E2 E3 E4) ty} -> typeOfH EnvH H -> true -> progresses (for E1 E2 E3 E4) H. 
skip. 


Theorem Progress-foreach: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (foreach E1 E2) ty} -> typeOfH EnvH H -> true -> progresses (foreach E1 E2) H. 
skip. 


Theorem Progress-seq: forall EnvH, forall E1, forall E2, forall ty, forall H, {typeOf (nilEnvT) EnvH (seq E1 E2) ty} -> typeOfH EnvH H -> progresses E1 H -> progresses (seq E1 E2) H. 
skip. 


Theorem Progress-L1: forall EnvH, forall L1, forall ty, forall H, {typeOf (nilEnvT) EnvH (labelH L1) ty} -> typeOfH EnvH H -> true -> progresses (labelH L1) H. 
skip. 


Theorem Progress-unit: forall EnvH, forall ty, forall H, {typeOf (nilEnvT) EnvH (unit) ty} -> typeOfH EnvH H -> true -> progresses (unit) H. 
skip. 


Theorem Progress-thm: forall EnvH, forall e, forall typ, forall H, {typeOf (nilEnvT) EnvH e typ} -> typeOfH EnvH H -> progresses e H. 
IH0 : induction on 1. intros Main TypeOfH. Typing0: case Main.  
 backchain Progress-num.  
 backchain Progress-tt.  
 backchain Progress-ff.  
 apply IH0 to Typing0 TypeOfH .  
 apply IH0 to Typing1 TypeOfH .  
 backchain Progress-plus.  
 backchain Progress-nilL.  
 backchain Progress-consL.  
 apply IH0 to Typing0 TypeOfH .  
 apply IH0 to Typing1 TypeOfH .  
 backchain Progress-equal.  
 apply IH0 to Typing0 TypeOfH .  
 backchain Progress-deref.  
 apply IH0 to Typing0 TypeOfH .  
 apply IH0 to Typing1 TypeOfH .  
 backchain Progress-assign.  
 apply IH0 to Typing0 TypeOfH .  
 backchain Progress-if.  
 backchain Progress-while.  
 backchain Progress-repeat.  
 backchain Progress-for.  
 backchain Progress-foreach.  
 apply IH0 to Typing0 TypeOfH .  
 backchain Progress-seq.  
 backchain Progress-L1.  
 backchain Progress-unit. 


Theorem Type-preservation: forall EnvH, forall e, forall typ, forall H, forall e', forall H', {typeOf (nilEnvT) EnvH e typ} -> typeOfH EnvH H -> {step e H e' H'} -> exists EnvH', {subsetEnvH EnvH EnvH'} /\ {typeOf (nilEnvT) EnvH' e' typ} /\ typeOfH EnvH' H'. 
IH0 : induction on 1. intros Main TypeOfH Step. Typing0: case Main.  
 Beginsnum: apply Step. 
 Prem0: case Step(keep).  
  
 Beginstt: apply Step. 
 Prem0: case Step(keep).  
  
 Beginsff: apply Step. 
 Prem0: case Step(keep).  
  
 Beginsplus: apply Step. 
