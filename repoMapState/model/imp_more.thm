Specification "imp_more".

%Close typ. Close label. Close term.

Define progresses : term -> mapH -> prop by
     progresses E H := {value E} ;
     progresses E H := exists E' H', {step E H E' H'}.

Define typeOfH: envH -> mapH -> prop by
    typeOfH EnvH MapH := forall l, forall t,
        {lookupEnvH EnvH l t} ->
        exists e, {lookupMapH MapH l e} /\ {typeOf (nilEnvT) EnvH e t}.

Theorem  Find-type-in-envH  : forall envH mapH L e T, {lookupMapH mapH L e} -> typeOfH envH mapH -> {typeOf (nilEnvT) envH (labelH L) (refH T)} -> {typeOf (nilEnvT) envH e T}. 
skip. 

Theorem TypeOf-updateH: 
    %assert 
	forall envH mapH mapH' e T L,
    typeOfH envH mapH ->
    {typeOf nilEnvT envH (labelH L) (refH T)} ->
	{typeOf nilEnvT envH e T} ->
    {updateMapH mapH L e mapH'} ->
    typeOfH envH mapH'.
skip. 

Theorem TypeOf-weakeningH: 
	forall envH mapH E T l,
    typeOfH envH mapH ->
    {typeOf nilEnvT envH E T} ->
    typeOfH (consEnvH l T envH) (consMapH l E mapH).
skip. 

Theorem TypeOf-addH : forall mapH E mapH' L T envH,  
{addMapH mapH E mapH' L} -> typeOfH (consEnvH L T envH) (consMapH L E mapH) -> typeOfH (consEnvH L T envH) mapH'. 
skip.



Theorem Type-state-envs-weakening: 
	%assert 
	forall gamma envH e t envH',
    {typeOf gamma envH e t} ->
    {subsetEnvH envH envH'} ->
    {typeOf gamma envH' e t}.
skip. 


Theorem Find-type-user-defined-addition: 
	%assert 
	forall EnvH V1 V2 V3, 
	{addition V1 V2 V3} -> 
	{typeOf nilEnvT EnvH V1 int} -> 
	{typeOf nilEnvT EnvH V2 int} -> 
	{typeOf nilEnvT EnvH V3 int}. 
skip. 


Theorem Find-type-user-defined-equality: 
	%assert 
	forall EnvH V1 V2 V3, 
	{equality V1 V2 V3} -> 
	{typeOf nilEnvT EnvH V1 int} -> 
	{typeOf nilEnvT EnvH V2 int} -> 
	{typeOf nilEnvT EnvH V3 bool}. 
skip. 



Theorem Canonical-form-int: forall EnvH, forall e, {typeOf (nilEnvT) EnvH e (int)} -> {value e} -> exists N, e = (num N). 
intros Main ValHyp.  
 case Main(keep).  
 search.  
  
  
 Mplus: case ValHyp(keep).  
  
  
  
 Mderef: case ValHyp(keep).  
  
  
  
  
  
  
  
  
 


