Heap H ::= [L |-> E]
Memory M ::= [L |-> E]
Type T ::= (arrow T T) | (refH T) | (refM T) | (unitT) | (times T T)
Expression E ::= x | (abs T (x)E) | (app E E) | (ref E) | (deref E) | (assign E E) | (labelH L) | (labelM Lm) | (unit) | (refAndStore E) | (assignAndRef E E E) | (pair E E)
Value V ::= (abs T R) | (labelH L) | (labelM L) | (unit) | (pair V1 V2)
Error ::=
Context C ::= [] | (app C e) | (app v C) | (ref C) | (deref C) | (assign C e) | (assign v C) | (refAndStore C) | (assignAndRef C e e) | (assignAndRef v C e) | (assignAndRef v v C) 
Relation R ::= (step E H M E H M)
.
Gamma ; EnvH ; EnvM |- (abs T1 R) : (arrow T1 T2) <== Gamma, x : T1 ; EnvH ; EnvM |- R : T2.
Gamma ; EnvH ; EnvM |- (app E1 E2) : T2 <== Gamma ; EnvH ; EnvM |- E1 : (arrow T1 T2) /\ Gamma ; EnvH ; EnvM |- E2 : T1.
Gamma ; EnvH ; EnvM |- (ref E): (refH T) <== Gamma ; EnvH ; EnvM |- E : T.
Gamma ; EnvH ; EnvM |- (deref E): T <== Gamma ; EnvH ; EnvM |- E : (refH T).
Gamma ; EnvH ; EnvM |- (assign E1 E2): (unitT) <== Gamma ; EnvH ; EnvM |- E1 : (refH T) /\ Gamma ; EnvH ; EnvM |- E2: T.
Gamma ; EnvH ; EnvM |- (labelH L) : (refH T) <== T <- HT@H(L).
Gamma ; EnvH ; EnvM |- (labelM L) : (refM T) <== T <- MT@H(L).
Gamma ; EnvH ; EnvM |- (unit ) : (unitT ).

Gamma ; EnvH ; EnvM |- (refAndStore E): (times (refH T) (times (refH (refM (refH T))) (refM (refH T)))) <== Gamma ; EnvH ; EnvM |- E : T.
Gamma ; EnvH ; EnvM |- (assignAndRef E1 E2 E3): (unitT) <== 
	Gamma ; EnvH ; EnvM |- E1 : (ref T) /\
	Gamma ; EnvH ; EnvM |- E2 : T /\
	Gamma ; EnvH ; EnvM |- E3 : T. 

Gamma ; EnvH ; EnvM |- (pair E1 E2): (times T1 T2) <== Gamma ; EnvH ; EnvM |- E1 : T1 /\ Gamma ; EnvH ; EnvM |- E2 : T2.


(app (abs T R) V); H ; M --> R[V/x]; H ; M <== value V.
(ref V); H ; M --> (labelH LNewH); H' ; M <== 
	H'@H, LNewH <- H + V /\ 
	H' <: (env (labelH LNewH) (refH T) (consEnvH LNewH T EnvH) EnvM).

(deref (labelH L)); H ; M --> V; H ; M <== V <- H@H(L).
(assign (labelH L) V); H ; M --> (unit); H' ; M <== H'@H <- H[L|->V].

(refAndStore V); H ; M --> (pair (labelH LNewH) (pair (labelH LNewH2) (labelM LNewM))); H'' ; M' <== 
	H'@H, LNewH <- H + V /\ 
	M'@M, LNewM <- M + (labelH LNewH) /\ 
	H''@H, LNewH2 <- H' + (labelM LNewM) /\ 
	H' <: (env (labelH LNewH) (refH T) (consEnvH LNewH T EnvH) EnvM) /\ 
	M' <: (env (labelM LNewM) (refM (refH T)) (consEnvH LNewH T EnvH) (consEnvM LNewM (refH T) EnvM)) /\ 
	H'' <: (env (labelH LNewH2) (refH (refM (refH T))) (consEnvH LNewH2 (refM (refH T)) (consEnvH LNewH T EnvH)) (consEnvM LNewM (refH T) EnvM)). 

(assignAndRef (labelH L) V V2) ; H ; M --> (unit); H'' ; M'' <== 
	Ha'@H <- H[L|->V] /\ 
	H''@H, LNewH <- Ha' + (labelH L) /\ 
	M'@M, LNewM <- M + V /\ 
	M''@M <- M'[LNewM|->V2] /\
	H'' <: (env (labelH LNewH) (refH (refH T)) (consEnvH LNewH (refH T) EnvH) EnvM) /\
	M' <: (env (labelM LNewM) (refM T) (consEnvH LNewH (refH T) EnvH) (consEnvM LNewM T EnvM) (varAffected V2)). 
	
